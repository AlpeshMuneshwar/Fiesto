// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Cafe {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique // used for URLs e.g. cafeqr.com/cafe/slug
  logoUrl     String?
  coverImage  String?
  galleryImages String? @db.Text
  address     String?
  city        String?
  latitude    Float?
  longitude   Float?
  isFeatured  Boolean  @default(false)
  featuredPriority Int @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  tables      Table[]
  menuItems   MenuItem[]
  orders      Order[]
  sessions    Session[]
  staffCalls  StaffCall[]
  activityLogs ActivityLog[]
  settings    CafeSettings?
  nearbyCafeRequests NearbyCafeRequest[]

  createdBy   String?
  updatedBy   String?
}

model NearbyCafeRequest {
  id         String   @id @default(uuid())
  city       String
  locality   String?
  latitude   Float?
  longitude  Float?
  note       String?
  customerEmail String?
  customerName String?
  source     String   @default("DISCOVERY_APP")
  cafeId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cafe       Cafe? @relation(fields: [cafeId], references: [id])
}

model CafeSettings {
  id                    String  @id @default(uuid())
  cafeId                String  @unique

  // Payment Workflow: WAITER_AT_TABLE | PAY_AT_COUNTER | BOTH
  paymentMode           String  @default("WAITER_AT_TABLE")

  // Tax & Charges
  taxEnabled            Boolean @default(false)
  taxRate               Float   @default(0)
  taxLabel              String  @default("GST")
  gstNumber             String? // Store Cafe's GST Identification Number
  taxInclusive          Boolean @default(false)
  serviceChargeEnabled  Boolean @default(false)
  serviceChargeRate     Float   @default(0)

  // Feature Toggles
  customerCanCallWaiter Boolean @default(true)
  specialInstructions   Boolean @default(true)
  locationVerification  Boolean @default(false)
  autoAcceptOrders      Boolean @default(false)
  showPrepTime          Boolean @default(false)
  avgPrepTimeMinutes    Int     @default(15)
  dietaryTagsEnabled    Boolean @default(true)
  menuImagesEnabled     Boolean @default(true)

  // Currency
  currency              String  @default("INR")
  currencySymbol        String  @default("₹")

  // Reservations & Pre-booking (Phase 4)
  platformFeeAmount   Float   @default(10.0)
  preOrderAdvanceRate Float   @default(40.0) // percentage for pre-booking
  reservationsEnabled Boolean @default(true)

  cafe                  Cafe    @relation(fields: [cafeId], references: [id])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  createdBy             String?
  updatedBy             String?
}

model User {
  id        String   @id @default(uuid())
  cafeId    String?
  name      String
  email     String   @unique
  password  String
  role      String   @default("WAITER") // SUPER_ADMIN, ADMIN, WAITER, CHEF
  isActive  Boolean  @default(true)
  pushToken String?  // Expo push notification token
  otp       String?
  otpExpires DateTime?
  isEmailVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  cafe      Cafe?    @relation(fields: [cafeId], references: [id])
  approvedOrders Order[] @relation("WaiterApprovals")
  sessions  Session[]
  activityHistory ActivityLog[]
  preparedOrders Order[] @relation("ChefOrders")
  
  createdBy String?
  updatedBy String?
}

model Table {
  id        String   @id @default(uuid())
  cafeId    String
  number    Int
  capacity  Int      @default(4)
  desc      String?
  qrCodeUrl String?
  qrToken   String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cafe      Cafe     @relation(fields: [cafeId], references: [id])
  sessions  Session[]
  staffCalls StaffCall[]

  createdBy String?
  updatedBy String?

  @@unique([cafeId, number])
}

model Session {
  id        String   @id @default(uuid())
  cafeId    String
  tableId   String?
  customerId String?
  isActive  Boolean  @default(true)
  isPrebooked Boolean @default(false)
  deviceIdentifier String?
  joinCode  String?
  scheduledAt DateTime?
  slotDurationMinutes Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cafe      Cafe     @relation(fields: [cafeId], references: [id])
  table     Table?    @relation(fields: [tableId], references: [id])
  customer  User?    @relation(fields: [customerId], references: [id])
  orders    Order[]
  staffCalls StaffCall[]

  createdBy String?
  updatedBy String?
}

model Order {
  id                  String   @id @default(uuid())
  cafeId              String
  sessionId           String
  waiterId            String?
  chefId              String?
  status              String   @default("PENDING_APPROVAL")
  orderType           String   @default("DINE_IN") // DINE_IN, TAKEAWAY, PRE_ORDER
  isLocationVerified  Boolean  @default(false)
  items               String   // JSON stringified array of order items
  specialInstructions String?  // "No onions, extra spicy"
  
  // Pricing
  subtotal            Float    @default(0)
  taxAmount           Float    @default(0)
  serviceCharge       Float    @default(0)
  platformFee         Float    @default(0)
  totalAmount         Float    // grandTotal
  
  // Pre-ordering
  isPreorder          Boolean  @default(false)
  advancePaid         Float    @default(0)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  cafe    Cafe    @relation(fields: [cafeId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])
  waiter  User?   @relation("WaiterApprovals", fields: [waiterId], references: [id])
  chef    User?   @relation("ChefOrders", fields: [chefId], references: [id])
  payment Payment?

  createdBy String?
  updatedBy String?
}

model StaffCall {
  id        String   @id @default(uuid())
  cafeId    String
  tableId   String?
  sessionId String
  type      String   @default("WAITER_CALL") // WAITER_CALL, CHEF_CALL
  status    String   @default("PENDING")     // PENDING, ACKNOWLEDGED, COMPLETED
  message   String?
  staffId   String?  // Waiter who acknowledged
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cafe    Cafe    @relation(fields: [cafeId], references: [id])
  table   Table?   @relation(fields: [tableId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  createdBy String?
  updatedBy String?
}

model Payment {
  id             String        @id @default(uuid())
  orderId        String        @unique
  amount         Float
  status         String        @default("PENDING")
  provider       String        @default("MANUAL")
  paymentStage   String        @default("PENDING") // PENDING, ACKNOWLEDGED, COMPLETED
  receiptImgUrl  String?
  providerOrderId String?      @unique
  providerPaymentId String?    @unique
  providerSignature String?
  webhookEventId String?       @unique
  webhookPayload String?       @db.Text
  lastError      String?       @db.Text
  webhookReceivedAt DateTime?
  capturedAt     DateTime?
  transactionId  String?
  waiterVerified Boolean       @default(false)
  acknowledgedAt DateTime?
  acknowledgedBy String?       // User ID of waiter who acknowledged
  billEmail      String?       // Customer email for receipt
  emailSentAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  order Order     @relation(fields: [orderId], references: [id])

  createdBy String?
  updatedBy String?
}

model MenuItem {
  id          String   @id @default(uuid())
  cafeId      String
  name        String
  desc        String   @default("")
  price       Float
  category    String   @default("General")
  imageUrl    String?  // menu item photo URL
  dietaryTag  String?  // VEG, NON_VEG, VEGAN, EGGETARIAN
  isAvailable Boolean  @default(true)
  isActive    Boolean  @default(true)
  lastStockUpdate DateTime @default(now())
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cafe        Cafe     @relation(fields: [cafeId], references: [id])

  createdBy   String?
  updatedBy   String?
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(uuid())
  cafeId      String
  staffId     String?  // Reference to User.id
  role        String?  // WAITER, CHEF, ADMIN, CUSTOMER
  actionType  String   // e.g., "ORDER_PLACED", "SESSION_CLOSED", "CLEAN_TABLE"
  message     String?  // Human readable summary
  metadata    String?  @db.Text // JSON string for detailed changes/payloads
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cafe  Cafe   @relation(fields: [cafeId], references: [id])
  staff User?  @relation(fields: [staffId], references: [id])
}
