PORT=4000
DATABASE_URL="mysql://your_user:your_password@127.0.0.1:3306/your_db_name"
JWT_SECRET="your_jwt_secret_here"
JWT_ACCESS_EXPIRY="100m"
JWT_REFRESH_EXPIRY="7d"
APP_BASE_URL="https://your-public-domain.com"
CORS_ORIGINS="https://your-public-domain.com,https://www.your-public-domain.com,http://localhost:3000,http://localhost:8081"

# Platform Fee Configuration
RESERVATIONS_ENABLED_DEFAULT=true
PLATFORM_FEE_AMOUNT=10.0
PRE_ORDER_ADVANCE_RATE=40.0
PREORDER_PAYMENT_WINDOW_MINUTES=60

# Email Configuration (for receipts)
EMAIL_USER="your_email@gmail.com"
EMAIL_APP_PASSWORD="your_app_password"
SMTP_FROM="Cafe QR Support <your_email@gmail.com>"

# Razorpay Configuration
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"
